# ─────────────────────────────────────────────────────────────────────────────
# VitalPath Frontend — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the Rust/Actix-web backend.
# In development the Vite dev-server proxy rewrites /api/* requests to this
# URL, so you do NOT expose this to the browser bundle directly.
# In production set this to the actual deployed backend origin.
VITE_API_BASE_URL=http://localhost:8080

# Application display name (shown in the browser tab and header)
VITE_APP_NAME=VitalPath Health Operations
