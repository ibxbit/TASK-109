# =============================================================================
# VitalPath environment configuration
# =============================================================================
# Copy to .env and fill in real values before running docker compose.
#
#   cp .env.example .env
#
# Never commit .env to version control.
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=vitalpath
POSTGRES_PASSWORD=change_me_use_strong_password
POSTGRES_DB=vitalpath_db

# ── Application ───────────────────────────────────────────────────────────────
# Constructed from the Postgres vars above — update all three if you rename.
DATABASE_URL=postgres://vitalpath:change_me_use_strong_password@db:5432/vitalpath_db

# JWT signing key (min 32 chars)
# Generate: openssl rand -base64 32
JWT_SECRET=change_me_in_production_min_32_chars!!

# AES-256-GCM field-level encryption key (32 raw bytes, base64-encoded)
# Generate: openssl rand -base64 32
FIELD_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# HMAC signing secret
# Generate: openssl rand -hex 32
HMAC_SECRET=change_me_in_production_use_openssl_rand_hex_32

# ── Backup ────────────────────────────────────────────────────────────────────
# AES-256-CBC passphrase for encrypted backup archives
# Generate: openssl rand -hex 32
BACKUP_ENCRYPTION_KEY=change_me_generate_with_openssl_rand_hex_32

# Days of daily backups to retain (older files are pruned automatically)
RETAIN_DAYS=30

# ── Server ────────────────────────────────────────────────────────────────────
RUST_LOG=info
HOST=0.0.0.0
PORT=8080
